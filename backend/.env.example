# Backend environment variables
# Copy to .env or set in your shell / Docker / host. Never commit real values.
#
# For local dev, most values have defaults in application.properties.
# Override these for production or Docker.

# Database (override for production)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/restaurantdb
# SPRING_DATASOURCE_USERNAME=restaurant_user
# SPRING_DATASOURCE_PASSWORD=your_db_password

# Security — use a long random string in production (e.g. openssl rand -base64 32)
# JWT_SECRET=your_min_32_char_secret_here

# CORS — comma-separated allowed origins (your frontend URL)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Base URL for receipts, password reset links, QR codes
# BASE_URL=http://localhost:5173

# Optional: SendGrid for emails
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM=noreply@yourdomain.com

# Optional: Stripe (set in application.properties or env)
# app.stripe.secret-key=sk_test_xxx
# app.stripe.webhook-secret=whsec_xxx
