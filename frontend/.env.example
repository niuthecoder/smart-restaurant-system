# Backend API URL (no trailing slash). Required for production.
# Docker backend: http://localhost:8081
# Local backend on 8080: http://localhost:8080
# Production: https://api.yourdomain.com (use HTTPS)
VITE_API_ORIGIN=http://localhost:8080

# Stripe publishable key (optional - backend can also expose via /api/payments/config)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
