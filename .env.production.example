# Production environment variables
# Copy to .env or set in your host / CI. Never commit real values.

# Required for production (Spring profile prod)
SPRING_PROFILES_ACTIVE=prod

# Database (required)
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_DB_HOST:5432/restaurantdb
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_strong_db_password

# Security (required) – use a long random string, e.g. openssl rand -base64 32
JWT_SECRET=your_min_32_char_secret_here

# Frontend URL for CORS and password reset links (required)
CORS_ORIGINS=https://yourdomain.com
BASE_URL=https://yourdomain.com

# Optional: SendGrid for password reset and notifications
# app.notification.sendgrid.api-key=SG.xxx
# app.notification.sendgrid.from=noreply@yourdomain.com
# app.notification.sendgrid.from-name=Your Restaurant

# Optional: Stripe payments (use live keys in production)
# app.stripe.secret-key=sk_live_xxx
# app.stripe.webhook-secret=whsec_xxx
